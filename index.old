<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Functional Design Life</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen bg-[#f7f3ee] text-[#2b2a28]">

<section class="relative overflow-hidden border-b border-[#d8d1c8] bg-[linear-gradient(135deg,#f7f3ee_0%,#efe7dd_45%,#e7ece8_100%)]">
  <div class="mx-auto grid max-w-7xl gap-12 px-6 py-16 md:px-10 md:py-24 lg:grid-cols-2 lg:items-center">

    <div>
      <div class="mb-5 inline-flex border border-[#bda98c] bg-[#f3ece4] px-4 py-2 text-sm uppercase tracking-[0.18em] text-[#7c6651]">
        20 years of hands-on space transformation
      </div>

      <h1 class="text-5xl font-semibold leading-tight md:text-6xl">
        Spaces that feel clear, intentional, and easy to live or work in.
      </h1>

      <p class="mt-6 text-lg text-[#5c5751]">
        Organizing, decluttering, deep cleaning, installation, layout improvement, and full space optimization.
      </p>
    </div>

    <div>
      <img src="https://images.unsplash.com/photo-1615873968403-89e068629265?auto=format&fit=crop&w=1200&q=80"
           class="w-full h-[400px] object-cover border border-[#d8d1c8]">
    </div>

  </div>
</section>

<section class="mx-auto max-w-7xl px-6 py-16">
  <h2 class="text-3xl font-semibold mb-6">Choose your starting point</h2>

  <div class="grid gap-6 md:grid-cols-3">

    <div class="border p-6 bg-white">
      <h3 class="text-xl font-semibold">Homeowners & Renters</h3>
      <p class="mt-3 text-[#5c5751]">
        For people who want their home to feel calmer, cleaner, and more functional.
      </p>
      <a href="mailto:mrfetterolf@gmail.com" class="mt-5 inline-block bg-[#2d4a41] text-white px-4 py-2">
        I Want My Home to Work Better
      </a>
    </div>

    <div class="border p-6 bg-white">
      <h3 class="text-xl font-semibold">Professionals & Workspaces</h3>
      <p class="mt-3 text-[#5c5751]">
        Offices, studios, and shops that need better systems and layout.
      </p>
      <a href="mailto:mrfetterolf@gmail.com" class="mt-5 inline-block bg-[#2d4a41] text-white px-4 py-2">
        I Need a Better Workspace
      </a>
    </div>

    <div class="border p-6 bg-white">
      <h3 class="text-xl font-semibold">Life Transitions & Estates</h3>
      <p class="mt-3 text-[#5c5751]">
        Divorce, loss, downsizing, or major life changes where you need to reset and rediscover your space.
      </p>
      <a href="mailto:mrfetterolf@gmail.com" class="mt-5 inline-block bg-[#2d4a41] text-white px-4 py-2">
        I Need Help With a Transition
      </a>
    </div>

  </div>
</section>

<section class="bg-[#2d4a41] text-white text-center py-16">
  <h2 class="text-3xl font-semibold">Ready to transform your space?</h2>
  <p class="mt-4">Contact for a quote or consultation</p>
  <a href="mailto:mrfetterolf@gmail.com" class="mt-6 inline-block bg-white text-[#2d4a41] px-6 py-3">
    Contact Me
  </a>
</section>

</body>
</html>